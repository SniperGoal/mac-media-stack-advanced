# rclone configuration examples
# Full docs: https://rclone.org/docs/
#
# Copy this file to ${MEDIA_DIR}/config/rclone/rclone.conf and edit.
# Or run: docker run --rm -it -v ${MEDIA_DIR}/config/rclone:/config/rclone rclone/rclone config

# ── Google Drive ─────────────────────────────────────────────────────
# https://rclone.org/drive/
# [gdrive]
# type = drive
# client_id =
# client_secret =
# scope = drive
# token = {"access_token":"...","token_type":"Bearer","refresh_token":"...","expiry":"..."}
# team_drive =

# ── Backblaze B2 ─────────────────────────────────────────────────────
# https://rclone.org/b2/
# [b2]
# type = b2
# account = YOUR_ACCOUNT_ID
# key = YOUR_APPLICATION_KEY

# ── Amazon S3 ────────────────────────────────────────────────────────
# https://rclone.org/s3/
# [s3]
# type = s3
# provider = AWS
# access_key_id = YOUR_ACCESS_KEY
# secret_access_key = YOUR_SECRET_KEY
# region = us-east-1

# ── Dropbox ──────────────────────────────────────────────────────────
# https://rclone.org/dropbox/
# [dropbox]
# type = dropbox
# token = {"access_token":"...","token_type":"bearer","refresh_token":"...","expiry":"..."}

# ── Local path (useful for testing) ──────────────────────────────────
# [local-test]
# type = local
# nounc = true

# ── NAS via SFTP (recommended for TrueNAS, Synology, Unraid) ────────
# https://rclone.org/sftp/
# SFTP gives ~100MB/s on Gigabit LAN (vs ~20MB/s for rclone SMB).
# SSH key auth recommended for unattended operation.
#
# The setup wizard can generate keys for you:
#   bash scripts/setup-cloud-storage.sh --storage-type nas

# TrueNAS (key auth)
# [mynas]
# type = sftp
# host = 192.168.1.100
# user = media
# key_file = /config/rclone/nas_key.pem

# Synology (key auth + path override for SFTP chroot)
# [synology]
# type = sftp
# host = 192.168.1.101
# user = media
# key_file = /config/rclone/nas_key.pem
# sftp_path_override = /volume1/media

# Unraid (key auth)
# [unraid]
# type = sftp
# host = 192.168.1.102
# user = root
# key_file = /config/rclone/nas_key.pem

# Generic NAS (password auth — run: rclone obscure YOUR_PASSWORD)
# [nas-password]
# type = sftp
# host = 192.168.1.100
# user = media
# pass = OBSCURED_PASSWORD_HERE
