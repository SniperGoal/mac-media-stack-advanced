# =============================================================
# Media Stack Configuration (Advanced)
# =============================================================
# Copy this file to .env and fill in the values below.
# =============================================================

# --- MEDIA SERVER ---
# plex (default, runs natively on macOS) or jellyfin (runs in Docker)
MEDIA_SERVER=plex

# --- TDARR ---
# native (recommended on macOS) or docker
TDARR_MODE=native
# Optional pinned Tdarr version for native mode (blank = latest available)
TDARR_VERSION=

# --- PATHS ---
MEDIA_DIR=/Users/YOURUSERNAME/Media

# --- USER IDS ---
# Run: id -u  (default 501 is correct for most Macs)
PUID=501
PGID=20

# --- TIMEZONE ---
TIMEZONE=America/New_York

# --- WEB ACCESS ---
# Seerr bind IP: keep 127.0.0.1 for local-only (recommended default).
# WARNING: Setting to 0.0.0.0 exposes Seerr to your entire network. Use 127.0.0.1 for local-only access.
SEERR_BIND_IP=127.0.0.1

# --- VPN (ProtonVPN WireGuard) ---
WIREGUARD_PRIVATE_KEY=your_wireguard_private_key_here
WIREGUARD_ADDRESSES=your_wireguard_address_here

# --- UNPACKERR API KEYS ---
# After first boot, get these from each service's Settings > General > API Key
# Unpackerr uses these to monitor Radarr/Sonarr for completed downloads to extract
UN_SONARR_0_API_KEY=your_sonarr_api_key_here
UN_RADARR_0_API_KEY=your_radarr_api_key_here

# --- JELLYSTAT (Jellyfin analytics, auto-generated by setup.sh) ---
JELLYSTAT_JWT_SECRET=
JELLYSTAT_DB_PASSWORD=

# --- OPTIONAL: MUSIC (Lidarr + Tidarr) ---
# Uncomment if using music services (bash scripts/setup-music.sh)
# UN_LIDARR_0_API_KEY=your_lidarr_api_key_here

# --- CLOUD STORAGE (rclone + mergerfs) ---
# Uncomment if using cloud storage (bash scripts/setup-cloud-storage.sh)
# Note: cloud-backed playback on macOS requires MEDIA_SERVER=jellyfin and TDARR_MODE=docker.
# CLOUD_STORAGE_ENABLED=true
# RCLONE_REMOTE=myremote
# RCLONE_REMOTE_PATH=
# RCLONE_VFS_CACHE_MODE=full
# RCLONE_VFS_CACHE_MAX_SIZE=50G
# RCLONE_VFS_CACHE_MAX_AGE=72h
# RCLONE_VFS_READ_CHUNK_SIZE=128M
# CLOUD_UPLOAD_MIN_AGE_HOURS=24
# RCLONE_DIR_CACHE_TIME=5m

# --- NAS STORAGE (rclone SFTP + mergerfs) ---
# Same infrastructure as cloud storage, optimized for LAN.
# Uses rclone SFTP to mount NAS inside Docker (where FUSE works on macOS).
# Run: bash scripts/setup-cloud-storage.sh --storage-type nas
#
# STORAGE_TYPE=nas
# CLOUD_STORAGE_ENABLED=true
# RCLONE_REMOTE=mynas
# RCLONE_REMOTE_PATH=/mnt/pool/dataset/media
# RCLONE_VFS_CACHE_MAX_SIZE=10G
# RCLONE_VFS_CACHE_MAX_AGE=1h
# RCLONE_VFS_READ_CHUNK_SIZE=32M
# RCLONE_DIR_CACHE_TIME=30s
# CLOUD_UPLOAD_MIN_AGE_HOURS=2
